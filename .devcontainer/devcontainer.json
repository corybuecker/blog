{
	"image": "mcr.microsoft.com/devcontainers/base:trixie",
	"runArgs": [
		"--cap-drop=ALL",
		"--security-opt=no-new-privileges"
	],
	"features": {
		"ghcr.io/devcontainers/features/rust:1.5.0": {
			"version": "1.94.1",
			"profile": "default"
		},
		"ghcr.io/devcontainers/features/node:1.7.1": {
			"version": "24.14.0",
			"pnpmVersion": "10.33.0"
		}
	}
}
